@{
    ViewData["Title"] = "Access Denied";
}

<div class="container main-content animate-in d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="col-lg-6 text-center">
        <div class="access-denied-icon mb-4">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <h1 class="display-4 text-gradient mb-3">Access Denied</h1>
        
        <div class="card p-4 border-color shadow-lg bg-card">
            <p class="text-secondary mb-4" style="font-size: 1.1rem; line-height: 1.6;">
                Oops! It looks like you don't have the required permissions to access this high-level clearance area.
                This section is restricted to <span class="text-white fw-bold">Authorized Administrators</span> only.
            </p>

            <div class="d-flex flex-column flex-md-row gap-3 justify-content-center">
                <a href="/" class="btn-primary py-2 px-4">
                    <i class="bi bi-house-door me-2"></i> Return to TechShop
                </a>
                <a href="javascript:history.back()" class="btn-outline py-2 px-4">
                    <i class="bi bi-arrow-left me-2"></i> Go Back
                </a>
            </div>
        </div>

        <div class="mt-4">
            <p class="text-muted small">
                If you believe this is an error, please contact your system architect.
                <br>Error Code: <span class="text-secondary fw-mono">403 - FORBIDDEN_ACCESS</span>
            </p>
        </div>
    </div>
</div>