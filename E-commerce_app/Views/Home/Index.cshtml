@{
    ViewData["Title"] = "Home";
}

<div class="main-content animate-in">
    <!-- Hero Section -->
    <section class="hero-section text-center py-5 mb-5">
        <div class="container">
            <h1 class="display-3 fw-bold text-gradient mb-3">Evolutionize Your Setup</h1>
            <p class="lead text-secondary mb-5 mx-auto" style="max-width: 700px;">
                Discover the next generation of high-performance hardware, precision peripherals, and cutting-edge components curated for elite enthusiasts.
            </p>
            <div class="d-flex gap-3 justify-content-center">
                <a asp-controller="Product" asp-route-pg="1" class="w-50 btn-primary py-3 px-5">
                    <i class="bi bi-cpu me-2 mx-auto"></i> Shop Now
                </a>
                
            </div>
        </div>
    </section>

    <!-- Features Ribbon -->
    <div class="container mb-5">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="card p-4 border-color h-100 bg-card">
                    <i class="bi bi-lightning-charge text-gradient fs-1 mb-3"></i>
                    <h5 class="text-white">Next-Day Delivery</h5>
                    <p class="small mb-0">Get your gear faster with our expedited shipping network.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 border-color h-100 bg-card">
                    <i class="bi bi-shield-check text-gradient fs-1 mb-3"></i>
                    <h5 class="text-white">Certified Hardware</h5>
                    <p class="small mb-0">Every component is tested for stability and performance.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 border-color h-100 bg-card">
                    <i class="bi bi-headset text-gradient fs-1 mb-3"></i>
                    <h5 class="text-white">Expert Support</h5>
                    <p class="small mb-0">24/7 technical assistance for your custom builds.</p>
                </div>
            </div>
        </div>
    </div>

</div>