@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container main-content animate-in">
    <!-- Header -->
    <div class="page-header mb-5">
        <h1 class="display-4 fw-bold text-gradient"><i class="bi bi-shield-check me-2"></i> Privacy Policy</h1>
        <p class="lead text-secondary">Your data security and privacy are our top priorities at TechShop.</p>
        <p class="small text-muted">Last Updated: May 2026</p>
    </div>

    <div class="row g-4">
        <!-- Main Content -->
        <div class="col-lg-8">
            <div class="card p-4 mb-4 border-color bg-card shadow-lg">
                <h3 class="text-white mb-3">1. Information Collection</h3>
                <p class="text-secondary">We collect information that helps us provide a premium shopping experience. This includes:</p>
                <ul class="text-secondary custom-list">
                    <li><strong>Account Data:</strong> Name, email address, and encrypted password.</li>
                    <li><strong>Order Details:</strong> Shipping address, phone number, and purchase history.</li>
                    <li><strong>Technical Data:</strong> IP address and browser type used for security and optimization.</li>
                </ul>
            </div>

            <div class="card p-4 mb-4 border-color bg-card">
                <h3 class="text-white mb-3">2. How We Use Your Data</h3>
                <p class="text-secondary">Your data is utilized strictly for the following purposes:</p>
                <ul class="text-secondary custom-list">
                    <li>Processing and shipping your high-performance hardware orders.</li>
                    <li>Providing real-time technical support for your purchases.</li>
                    <li>Improving site performance and user interface experience.</li>
                    <li>Preventing fraudulent activities and securing your account.</li>
                </ul>
            </div>

            <div class="card p-4 mb-4 border-color bg-card">
                <h3 class="text-white mb-3">3. Data Protection</h3>
                <p class="text-secondary">We implement industry-standard security measures, including SSL encryption for all data transfers and secure hashing for sensitive passwords. We never sell your personal information to third-party marketing firms.</p>
            </div>
        </div>

        <!-- Sidebar / Contact Box -->
        <div class="col-lg-4">
            <div class="card p-4 border-color bg-secondary position-sticky" style="top: 100px;">
                <h4 class="text-white mb-3"><i class="bi bi-info-circle text-accent"></i> Privacy Questions?</h4>
                <p class="text-secondary small">If you have concerns regarding your data or wish to request a data deletion, please reach out to our security team.</p>
                <hr class="border-color">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-envelope-at text-accent fs-4 me-3"></i>
                    <div>
                        <div class="text-white small fw-bold">Email Support</div>
                        <div class="text-muted small">privacy@techshop.com</div>
                    </div>
                </div>
                <a href="/Home/Contact" class="btn-outline w-100 py-2">Contact Us</a>
            </div>
        </div>
    </div>
</div>