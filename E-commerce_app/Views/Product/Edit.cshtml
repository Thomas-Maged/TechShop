@model ProductViewModel
@{
    ViewData["Title"] = "Edit";
}

<div class="container main-content animate-in">
    <div class="page-header mb-4">
        <h1 class="text-gradient">Edit Product</h1>
        <p class="text-secondary">Update technical specifications or remove inventory</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <form asp-action="Edit" method="post" id="editProductForm" enctype="multipart/form-data" class="card p-4 shadow-lg">
                
                <div class="form-group">
                    <label class="form-label required">Product Name</label>
                    <input type="text" asp-for="Name" class="form-control-checkout" required>
                    <span class="form-error">Please enter a valid product name.</span>
                </div>

                <div class="form-group">
                    <label class="form-label required">Description</label>
                    <textarea asp-for="Description" class="form-control-checkout" rows="4" required>Existing detailed technical specifications...</textarea>
                    <span class="form-error">Description is required.</span>
                </div>

                <div class="form-group">
                    <label class="form-label required">Category</label>
                    <select asp-for="CategoryID" class="form-control-checkout" required>
                        @foreach (var category in ViewBag.Categories)
                        {
                            if (category.CategoryID == Model.CategoryID)
                            {
                                <option value="@category.CategoryID" selected>@category.Name</option>
                            }
                            else
                            {
                                <option value="@category.CategoryID">@category.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label class="form-label required">Base Price ($)</label>
                        <input type="number" asp-for="Price" step="0.01" class="form-control-checkout" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label class="form-label">Discount (%)</label>
                        <input type="number" asp-for="DiscountPercentage" class="form-control-checkout" min="0" max="100">
                    </div>
                    <div class="col-md-4 form-group">
                        <label class="form-label required">Stock Quantity</label>
                        <input type="number" asp-for="StockQuantity" class="form-control-checkout" required>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Product Image</label>
                    <input type="file" asp-for="Image" id="imageUpload" class="form-control-checkout" accept="image/*">
                    <div id="imagePreviewContainer" class="mt-3">
                        <div class="order-item-image" style="width: 150px; height: 150px;">
                            <img id="imagePreview" src="@Model.ImagePath" alt="Current Image">
                        </div>
                        <small class="text-muted mt-1 d-block">Leave empty to keep current image</small>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActive" checked>
                        <label class="form-check-label text-white" for="isActive">Product is Active</label>
                    </div>
                </div>
                <input type="hidden" asp-for="ProductID" />
                <input type="hidden" asp-for="ImagePath" />
                <div class="d-grid gap-2 mt-4">
                    <button type="submit" id="saveBtn" class="btn-primary py-3">
                        <i class="bi bi-save me-2"></i>Save Changes
                    </button>
                    
                    <button type="button" class="btn-outline text-danger border-danger py-2" data-bs-toggle="modal" data-bs-target="#deleteModal">
                        <i class="bi bi-trash3 me-2"></i>Delete Product
                    </button>
                    
                    <a asp-action="Index" asp-route-pg="1" class="back-to-cart justify-content-center">
                        <i class="bi bi-arrow-left"></i> Back to Inventory
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-card border-color shadow-lg overflow-hidden" style="border-radius: var(--radius-lg);">
            <div class="modal-header border-bottom border-color p-4">
                <h5 class="modal-title text-white fw-bold d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill text-danger"></i> Confirm Deletion
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p class="text-secondary mb-0" style="font-size: var(--font-lg); line-height: var(--leading-normal);">
                    Are you sure you want to delete <span class="text-white fw-bold">"@Model.Name"</span>?
                    <br>
                    <small class="text-muted d-block mt-2" style="font-size: var(--font-sm);">This action is permanent and cannot be reversed.</small>
                </p>
            </div>
            <div class="modal-footer border-top border-color p-4 justify-content-center">
                <button type="button" class="btn-outline px-4 py-3" data-bs-dismiss="modal" style="min-width: 120px; font-weight: 600;">Cancel</button>
                <a  asp-action="Delete" asp-route-id="@Model.ProductID" type="button" id="confirmDeleteBtn" class="btn-primary px-4 py-3"
                        style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); border: none; min-width: 180px; font-weight: 700;">
                    Delete Permanently
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
                $(document).ready(function() {
            // 1. Handle Delete Confirmation
            $('#confirmDeleteBtn').on('click', function() {
                const btn = $(this);
                btn.addClass('loading');
                btn.text('Deleting...');
        
                console.log("Delete request sent to backend...");

              });

            // 2. Reuse the Image Preview from Add Product page
            $('#imageUpload').on('change', function() {
                const file = this.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#imagePreview').attr('src', e.target.result);
                    }
                    reader.readAsDataURL(file);
                }
            });

            // 3. Edit Form Validation
            $('#editProductForm').on('submit', function(e) {
                let isValid = true;
                $(this).find('input[required], textarea[required]').each(function() {
                    if (!$(this).val()) {
                        $(this).addClass('is-invalid');
                        isValid = false;
                    } else {
                        $(this).removeClass('is-invalid');
                    }
                });

                if (isValid) {
                    $('#saveBtn').addClass('loading').prop('disabled', true);
                } else {
                    e.preventDefault();
                }
            });
        });
    </script>
}
