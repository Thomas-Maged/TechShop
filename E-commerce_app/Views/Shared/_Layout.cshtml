<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechShop</title>

    <!-- Google Fonts -->
    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />



    <!-- Local Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />


    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg" id="mainNavbar">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-cpu me-2"></i>TECHSHOP
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent"
                    aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation"
                    style="border-color: var(--border-accent);">
                <span style="color: var(--accent-primary);">
                    <i class="bi bi-list" style="font-size: 1.5rem;"></i>
                </span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index" asp-route-pg="1" asp-route-catID="all">
                            <i class="bi bi-grid me-1"></i>Products
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Order" asp-action="Index">
                            <i class="bi bi-box-seam me-1"></i>Orders
                        </a>
                    </li>

                    @if (!User.IsInRole("admin"))
                    {
                        <li class="nav-item position-relative">
                            <a class="nav-link" asp-area="" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3 me-1"></i>Cart
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("admin"))
                    {
                        <li class="nav-item position-relative">
                            <a class="nav-link" asp-area="" asp-controller="Category" asp-action="Index">
                                <i class="bi bi-tags"></i> Categories
                            </a>
                        </li>
                    }
                        
                </ul>

                <!-- Search Bar -->
                <form asp-area="" asp-controller="Product" asp-action="Index" method="get" class="search-container">
                    <i class="bi bi-search search-icon"></i>
                    <input type="hidden" name="pg" value="1" />
                    <input type="text" name="search" class="search-input form-control"
                           placeholder="Search products..." id="searchInput" />
                </form>

                <!-- User Menu -->
                <div class="ms-3">
                    <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Index">
                        <i class="bi bi-person-circle" style="font-size: 1.5rem;"></i>
                    </a>
                </div>

                <!-- User Account - Shows Login button OR User dropdown -->
                @if (User.Identity.IsAuthenticated)
                {
                    <!-- Logged in: Show user dropdown -->
                    <a href="@Url.Action("Logout", "Account")" class="btn-login-nav">
                        <i class="bi bi-box-arrow-in-left"></i>
                        Logout
                    </a>
                }
                else
                {
                    <!-- Not logged in: Show login button -->
                    <a href="@Url.Action("Login", "Account")" class="btn-login-nav">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Login
                    </a>
                }
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <!-- Company Info -->
                <div class="col-lg-3 col-md-6 footer-section">
                    <h5 class="footer-title">
                        <i class="bi bi-cpu me-2"></i>TECHSHOP
                    </h5>
                    <p style="color: var(--text-secondary); font-size: 0.9rem;">
                        Your premier destination for cutting-edge technology products.
                        Quality, innovation, and customer satisfaction guaranteed.
                    </p>
                    <div class="social-icons">
                        <a href="#" class="social-icon" aria-label="Facebook">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="#" class="social-icon" aria-label="Twitter">
                            <i class="bi bi-twitter-x"></i>
                        </a>
                        <a href="#" class="social-icon" aria-label="Instagram">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="#" class="social-icon" aria-label="LinkedIn">
                            <i class="bi bi-linkedin"></i>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="col-lg-3 col-md-6 footer-section">
                    <h5 class="footer-title">Quick Links</h5>
                    <a asp-area="" asp-controller="Home" asp-action="About" class="footer-link">About Us</a>
                    <a asp-area="" asp-controller="Products" asp-action="Index" class="footer-link">Shop Products</a>
                    <a asp-area="" asp-controller="Products" asp-action="Deals" class="footer-link">Special Deals</a>
                    <a asp-area="" asp-controller="Home" asp-action="Blog" class="footer-link">Tech Blog</a>
                    <a asp-area="" asp-controller="Home" asp-action="Careers" class="footer-link">Careers</a>
                </div>

                <!-- Customer Service -->
                <div class="col-lg-3 col-md-6 footer-section">
                    <h5 class="footer-title">Customer Service</h5>
                    <a asp-area="" asp-controller="Home" asp-action="Contact" class="footer-link">Contact Us</a>
                    <a asp-area="" asp-controller="Home" asp-action="Shipping" class="footer-link">Shipping Info</a>
                    <a asp-area="" asp-controller="Home" asp-action="Returns" class="footer-link">Returns & Refunds</a>
                    <a asp-area="" asp-controller="Home" asp-action="FAQ" class="footer-link">FAQ</a>
                    <a asp-area="" asp-controller="Home" asp-action="Support" class="footer-link">Tech Support</a>
                </div>

                <!-- Newsletter -->
                <div class="col-lg-3 col-md-6 footer-section">
                    <h5 class="footer-title">Stay Updated</h5>
                    <p style="color: var(--text-secondary); font-size: 0.9rem;">
                        Subscribe to get exclusive deals and product launches.
                    </p>
                    <form asp-area="" asp-controller="Home" asp-action="Subscribe" method="post" class="mb-3">
                        <div class="input-group">
                            <input type="email" name="email" class="search-input form-control"
                                   placeholder="Your email" aria-label="Email" required>
                            <button class="btn-primary btn" type="submit">
                                <i class="bi bi-send"></i>
                            </button>
                        </div>
                    </form>
                    <div class="mt-3">
                        <i class="bi bi-shield-check me-2" style="color: var(--accent-primary);"></i>
                        <small style="color: var(--text-secondary);">Secure payments</small>
                    </div>
                    <div class="mt-2">
                        <i class="bi bi-truck me-2" style="color: var(--accent-primary);"></i>
                        <small style="color: var(--text-secondary);">Free shipping over $50</small>
                    </div>
                </div>
            </div>

            <!-- Footer Bottom -->
            <div class="footer-bottom">
                <div class="row align-items-center">
                    <div class="col-md-6 text-center text-md-start">
                        <p class="mb-0">
                            &copy; @DateTime.Now.Year TechShop. All rights reserved.
                        </p>
                    </div>
                    <div class="col-md-6 text-center text-md-end">
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-link d-inline-block mx-2">Privacy Policy</a>
                        <a asp-area="" asp-controller="Home" asp-action="Terms" class="footer-link d-inline-block mx-2">Terms of Service</a>
                        <a asp-area="" asp-controller="Home" asp-action="Cookies" class="footer-link d-inline-block mx-2">Cookie Policy</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Local jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- Local Bootstrap JS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JavaScript -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
